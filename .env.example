# 复制为 .env 再填写:cp .env.example .env

# @BotFather 给的 token(必填)
BOT_TOKEN=123456:ABC-DEF...

# bundle 链接的对外前缀(建议设成你的域名;默认 http://localhost:8099)
# BUNDLE_BASE_URL=https://example.com

# bundle HTTP 监听地址(默认 :8099;套反代时可设 127.0.0.1:8099)
# BUNDLE_ADDR=:8099

# 启动时同步 bot 资料(等价 BotFather 的 /setname /setdescription /setabouttext;留空不动)
# BOT_NAME=Magibox
# BOT_DESCRIPTION=Playground, Plugin Like, Simple Telegram Bot.
# BOT_ABOUT=📦 Magic Complete

# 持久化路径(Docker 里默认落在 /data 卷,无需设置)
# AUTH_STORE=auth.json
# PLAYGROUND_STORE=playground.json
# VARS_STORE=vars.json
# BUNDLE_STORE=bundles.json
# BUNDLE_MEDIA_DIR=bundle-media
